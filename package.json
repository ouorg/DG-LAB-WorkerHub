{
  "name": "dg-lab-worker-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "./scripts/deploy-worker.sh",
    "db:migrate:local": "wrangler d1 migrations apply dg-lab-worker-hub --local",
    "db:migrate:remote": "wrangler d1 migrations apply dg-lab-worker-hub --remote",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test test/*.test.mjs",
    "deploy:dry-run": "DEPLOY_DRY_RUN=1 ./scripts/deploy-worker.sh",
    "actions:validate": "ruby scripts/validate-workflow.rb"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wrangler": "^4.95.0"
  }
}
